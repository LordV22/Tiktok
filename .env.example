# ============================================
# VIDEOBOT PRO - Configurações Seguras
# ============================================
# NUNCA commite este arquivo no Git!
# ============================================

# Telegram Bot Token (obtido de @BotFather)
BOT_TOKEN=

# Mistral AI API Key
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TEMPERATURE=0.3
MISTRAL_MAX_TOKENS=3000

# Segurança
MASTER_KEY=
WEBHOOK_SECRET=
ADMIN_ID=
ENCRYPTION_ENABLED=true

# Limites
MAX_VIDEO_DURATION=300
MAX_FILE_SIZE_MB=50
VIDEO_FPS=30
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
VIDEO_PRESET=slow
VIDEO_CRF=18

# Caminhos
TEMP_DIR=./temp
OUTPUT_DIR=./output
LOG_DIR=./logs

# Debug
DEBUG=false
LOG_LEVEL=INFO

# Usuários permitidos (separados por vírgula)
ALLOWED_USERS=
